# Configuration de sécurité pour StatDirm
# Copier ce fichier en .env et remplir les valeurs

# Identifiant pour l'authentification (par défaut: admin)
VITE_APP_USERNAME=admin

# Mot de passe pour l'authentification (à changer en production)
# En production, utiliser une authentification plus robuste (JWT, OAuth, etc.)
VITE_APP_PASSWORD=changez-moi-en-production

# Mode de l'application
NODE_ENV=production

# URL de l'API backend (si applicable)
# VITE_API_URL=https://api.votre-domaine.fr

# Clé de chiffrement pour les données sensibles (générer une clé aléatoire)
# VITE_ENCRYPTION_KEY=votre-cle-de-chiffrement-secrete

# Configuration HTTPS
# VITE_HTTPS_ENABLED=true

# Configuration du rate limiting
# VITE_RATE_LIMIT_REQUESTS=100
# VITE_RATE_LIMIT_WINDOW=60000
